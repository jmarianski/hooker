{
  "id": "block-dangerous-commands",
  "name": "Block Dangerous Commands",
  "description": "Blocks rm -rf, fork bombs, curl|sh, DROP TABLE, and other destructive bash commands.",
  "hooks": [
    "PreToolUse"
  ],
  "matchers": {
    "PreToolUse": "Bash"
  },
  "category": "safety",
  "attribution": {
    "type": "adapted",
    "author": "karanb192",
    "license": "MIT",
    "url": "https://github.com/karanb192/claude-code-hooks"
  },
  "compatibility": {
    "claude": "native",
    "codex": "native"
  }
}
