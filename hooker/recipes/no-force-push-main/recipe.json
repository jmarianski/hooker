{
  "id": "no-force-push-main",
  "name": "No Force Push to Main",
  "description": "Blocks git push --force to main/master branches.",
  "hooks": [
    "PreToolUse"
  ],
  "matchers": {
    "PreToolUse": "Bash"
  },
  "category": "safety",
  "attribution": {
    "type": "inspired",
    "author": "Common pattern (paddo.dev, Cameron Westland)",
    "license": "Blog posts",
    "url": "https://paddo.dev/blog/claude-code-hooks-guardrails/"
  },
  "compatibility": {
    "claude": "native",
    "codex": "native"
  }
}
