{
  "id": "refactor-move-markdown",
  "name": "Refactor Move Markdown Links",
  "description": "After mv of any file, updates relative links in .md files ([text](path) and image refs). Pure bash/sed — no external dependencies.",
  "hooks": [
    "PostToolUse",
    "PostCompact",
    "SessionStart"
  ],
  "matchers": {
    "PostCompact": "",
    "PostToolUse": "Bash",
    "SessionStart": ""
  },
  "category": "refactoring",
  "attribution": {
    "type": "original",
    "author": "Jacek Mariański",
    "license": "MIT"
  },
  "compatibility": {
    "claude": "native",
    "codex": "unsupported"
  }
}
