{
  "id": "session-guardian",
  "name": "Session Guardian",
  "description": "Lifecycle reminders: verify failed tools, check tests before task completion, re-inject context after compaction, remind to commit on session end, review subagent output.",
  "hooks": [
    "PostToolUseFailure",
    "TaskCompleted",
    "PostCompact",
    "SessionEnd",
    "SubagentStop"
  ],
  "matchers": {
    "PostCompact": "",
    "PostToolUseFailure": "",
    "SessionEnd": "",
    "SubagentStop": "",
    "TaskCompleted": ""
  },
  "category": "monitoring",
  "attribution": {
    "type": "original",
    "author": "Jacek Mariański",
    "license": "MIT"
  },
  "compatibility": {
    "claude": "native",
    "codex": "unsupported"
  }
}
