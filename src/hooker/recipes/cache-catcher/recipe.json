{
  "name": "Cache Catcher",
  "description": "Monitor Claude Code cache health. Warns or blocks when cache writes exceed reads, indicating broken prompt caching.",
  "version": "0.6.2",
  "hooks": ["SessionStart", "UserPromptSubmit", "PostToolUse", "Stop"],
  "compatibility": {
    "claude": "native",
    "codex": "unsupported"
  },
  "category": "monitoring",
  "attribution": {
    "type": "original",
    "author": "Jacek Mariański",
    "license": "MIT",
    "url": "https://treetank.net"
  },
  "plugin": {
    "output": "cache-catcher"
  }
}
