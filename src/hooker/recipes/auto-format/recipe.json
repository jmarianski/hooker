{
  "name": "Auto Format",
  "description": "Runs the appropriate formatter (prettier, ruff, gofmt, etc.) after every file edit.",
  "hooks": ["PostToolUse"],
  "matchers": {"PostToolUse": "Edit"},
  "async": {"PostToolUse": true},
  "cron": true,
  "category": "workflow",
  "attribution": {
    "type": "adapted",
    "author": "Ryan Lewis",
    "license": "MIT",
    "url": "https://github.com/ryanlewis/claude-format-hook"
  }
}
